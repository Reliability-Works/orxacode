{
  "name": "@orxa-code/server",
  "version": "0.0.15",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Reliability-Works/orxacode",
    "directory": "apps/server"
  },
  "bin": {
    "orxacode": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types src/bin.ts",
    "dev:build": "tsdown --watch",
    "build": "node scripts/cli.ts build",
    "start": "node dist/bin.mjs",
    "prepare": "effect-language-service patch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "@effect/platform-node": "4.0.0-beta.43",
    "@opencode-ai/sdk": "^1.4.0",
    "@pierre/diffs": "^1.1.0-beta.16",
    "effect": "4.0.0-beta.43",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@effect/language-service": "0.84.3",
    "@effect/vitest": "4.0.0-beta.43",
    "@orxa-code/contracts": "workspace:*",
    "@orxa-code/shared": "workspace:*",
    "@orxa-code/web": "workspace:*",
    "@types/node": "*",
    "tsdown": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}

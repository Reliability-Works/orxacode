{
  "name": "orxa-code",
  "private": true,
  "version": "0.1.0-beta.23",
  "description": "Orxa Code Electron desktop app",
  "author": "Reliability Works",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "native:rebuild": "electron-builder install-app-deps",
    "dev": "vite",
    "dev:mac": "node scripts/sync-macos-dev-icon.mjs && vite",
    "build": "tsc -b && vite build",
    "dist": "pnpm build && electron-builder",
    "dist:dir": "pnpm build && electron-builder --dir",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:coverage",
    "lint": "eslint .",
    "preview": "vite preview",
    "smoke:artifact": "node scripts/release-smoke-test.mjs",
    "postinstall": "pnpm native:rebuild",
    "predev": "pnpm native:rebuild",
    "predev:mac": "pnpm native:rebuild",
    "prebuild": "pnpm native:rebuild",
    "prepare": "husky"
  },
  "build": {
    "appId": "ai.orxa.code",
    "productName": "Orxa Code",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Reliability-Works",
        "repo": "OpencodeOrxa",
        "releaseType": "release"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=5.0.0 <5.1.7": "5.1.7",
      "minimatch@>=9.0.0 <9.0.6": "9.0.6"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@git-diff-view/react": "^0.0.39",
    "@opencode-ai/sdk": "^1.2.10",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "12.8.0",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "jsonc-parser": "^3.3.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.575.0",
    "node-pty": "1.2.0-beta.12",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "simple-icons": "^16.9.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.13",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}

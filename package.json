{
  "name": "orxacode",
  "private": true,
  "version": "0.1.0",
  "description": "Electron OpenCode monitor desktop app",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:mac": "node scripts/sync-macos-dev-icon.mjs && vite",
    "build": "tsc -b && vite build",
    "dist": "pnpm build && electron-builder",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:coverage",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "ai.orxa.opencode.monitor",
    "productName": "OrxaCode",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/orxa-template",
        "to": "orxa-template"
      }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Reliability-Works",
        "repo": "orxacode",
        "releaseType": "release"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@git-diff-view/react": "^0.0.39",
    "@opencode-ai/sdk": "^1.2.10",
    "clsx": "^2.1.1",
    "electron": "^40.6.0",
    "electron-updater": "^6.6.2",
    "electron-store": "^11.0.2",
    "jsonc-parser": "^3.3.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.575.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "simple-icons": "^16.9.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.13",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}

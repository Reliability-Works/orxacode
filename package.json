{
  "name": "orxa-code",
  "private": true,
  "version": "0.1.0-beta.79",
  "description": "Orxa Code monorepo root",
  "author": "Reliability Works",
  "main": "apps/desktop/dist-electron/main.js",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-root.mjs",
    "dev:desktop": "pnpm --filter @orxa-code/desktop dev",
    "dev:server": "pnpm --filter @orxa-code/server dev",
    "dev:web": "pnpm --filter @orxa-code/web dev",
    "build": "corepack pnpm -r --if-present build",
    "build:artifact:dir": "electron-builder --config electron-builder.yml --dir --publish never",
    "smoke:artifact": "node scripts/release-smoke-test.mjs",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "lint": "corepack pnpm exec eslint --no-error-on-unmatched-pattern apps packages scripts --ext .ts,.tsx,.js,.jsx,.mjs,.cjs",
    "duplication": "jscpd --config .jscpd.json apps packages",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "ci": "pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.4": "10.2.4",
      "rollup@<4.60.0": "4.60.0",
      "tar@<7.5.13": "7.5.13",
      "flatted@<3.4.2": "3.4.2",
      "undici@>=7.0.0 <7.24.6": "7.24.6",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@<2.0.0": "1.1.13",
      "brace-expansion@>=2.0.0 <3.0.0": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@effect/platform-node": "4.0.0-beta.43",
    "@opencode-ai/sdk": "^1.2.10",
    "@pierre/diffs": "^1.1.8",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "12.8.0",
    "ccount": "^2.0.1",
    "clsx": "^2.1.1",
    "comma-separated-tokens": "^2.0.3",
    "cytoscape": "^3.33.1",
    "effect": "4.0.0-beta.43",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "hast-util-to-html": "^9.0.5",
    "hast-util-whitespace": "^3.0.0",
    "html-void-elements": "^3.0.0",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.575.0",
    "mdast-util-to-hast": "^13.2.1",
    "ms": "^2.1.3",
    "node-pty": "1.2.0-beta.12",
    "prismjs": "^1.30.0",
    "property-information": "^7.1.0",
    "pure-rand": "8.4.0",
    "react": "^19.2.4",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.9.0",
    "space-separated-tokens": "^2.0.2",
    "stringify-entities": "^4.0.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-serialize": "^0.11.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-webgl": "^0.16.0",
    "zustand": "^5.0.12",
    "zwitch": "^2.0.4"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.13",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "depcheck": "^1.4.7",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "^28.1.0",
    "knip": "^6.0.6",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}

{
  "threshold": 0,
  "pattern": "**/src/**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,html}",
  "reporters": ["console", "html"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-electron/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test/**",
    "**/routeTree.gen.ts"
  ],
  "absolute": false,
  "gitignore": true
}

# Check for newly added large files (>100KB)
echo "Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=A | while IFS= read -r file; do
  if [ -f "$file" ]; then
    size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
    if [ "$size" -gt 102400 ]; then
      printf "%s (%s bytes)\n" "$file" "$size"
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo "Error: Newly added files larger than 100KB detected. Consider using Git LFS."
  echo "$LARGE_FILES"
  exit 1
fi

pnpm lint
pnpm typecheck

STAGED_FORMAT_FILES=$(git diff --cached --name-only --diff-filter=ACM | while IFS= read -r file; do
  if printf "%s" "$file" | grep -Eq '\.(js|jsx|ts|tsx|json|md|css|scss|yml|yaml)$'; then
    printf "%s\n" "$file"
  fi
done)

if [ -n "$STAGED_FORMAT_FILES" ]; then
  printf "%s\n" "$STAGED_FORMAT_FILES" | xargs pnpm exec prettier --check
fi

pnpm test:perf-guard
pnpm test:coverage

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "apps/desktop/src/main.ts",
    "apps/server/src/bin.ts",
    "apps/web/src/main.tsx",
    "scripts/*.mjs"
  ],
  "project": [
    "apps/**/*.{ts,tsx,mts,cts}",
    "packages/**/*.{ts,tsx,mts,cts}",
    "scripts/**/*.{ts,mts,cts,mjs,cjs}"
  ],
  "ignore": [
    "dist/**",
    "dist-electron/**",
    "coverage/**",
    "node_modules/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "ignoreBinaries": ["electron-builder", "tsc"],
  "ignoreDependencies": ["@types/*", "eslint-plugin-*"]
}
